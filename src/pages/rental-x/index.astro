---
import Layout from '~/layouts/Layout.astro';
import { rentalXPageList } from '~/data/rental-x-pages';

const metadata = {
  title: 'Rental X - Landing Pages',
  description: 'Implemented rental unit landing pages inspired by the Rental X Figma template.',
};
---

<Layout metadata={metadata}>
  <main class="min-h-screen bg-[#f6f6f6] py-12 text-[#111]">
    <div class="mx-auto w-full max-w-6xl px-4 md:px-6">
      <header class="overflow-hidden rounded-3xl bg-gradient-to-br from-[#1a120f] to-[#4b2c22] p-8 text-white md:p-12">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#ffb5b5]">Rental X Implementation</p>
        <h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-tight md:text-5xl">Real Astro pages from the Rental X hotel template</h1>
        <p class="mt-4 max-w-2xl text-sm text-white/85 md:text-base">
          These pages are implemented with real UI elements, connected route links, and interactive moving sections
          instead of static Figma screenshots.
        </p>
        <a href="/rental-x/home" class="mt-7 inline-flex rounded-full bg-[#ff4d4d] px-6 py-3 text-sm font-semibold text-white">Open Home page</a>
      </header>

      <section class="mt-10">
        <h2 class="text-2xl font-semibold">All implemented routes</h2>
        <ul class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            rentalXPageList.map((page) => (
              <li>
                <a
                  href={`/rental-x/${page.slug}`}
                  class="block h-full rounded-2xl border border-black/10 bg-white p-5 transition hover:-translate-y-1 hover:shadow-md"
                >
                  <h3 class="text-xl font-semibold">{page.title}</h3>
                  <p class="mt-2 text-sm text-black/70">{page.description}</p>
                  <span class="mt-4 inline-flex rounded-full bg-black px-3 py-1 text-xs font-semibold uppercase tracking-[0.08em] text-white"
                    >Open page</span
                  >
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </main>
</Layout>
