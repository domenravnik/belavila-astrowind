<main>
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?auto=format&fit=crop&w=2200&q=80"
      alt="Contact us"
      class="h-[46vh] min-h-[360px] w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="absolute inset-0 flex items-center justify-center px-4">
      <div class="text-center text-white">
        <p class="text-xs uppercase tracking-[0.18em] text-white/70">Get in touch</p>
        <h1 class="mt-3 text-4xl font-semibold md:text-6xl">Contact us</h1>
      </div>
    </div>
  </section>

  <section class="mx-auto grid w-full max-w-6xl gap-6 px-4 pt-14 md:grid-cols-3 md:px-6">
    <article class="rounded-2xl border border-black/10 bg-white p-5">
      <h2 class="text-lg font-semibold">Reservations</h2>
      <p class="mt-2 text-sm text-black/70">+1 (321) 555-2001</p>
      <p class="text-sm text-black/70">booking@rentalx.com</p>
    </article>
    <article class="rounded-2xl border border-black/10 bg-white p-5">
      <h2 class="text-lg font-semibold">Events & groups</h2>
      <p class="mt-2 text-sm text-black/70">+1 (321) 555-2008</p>
      <p class="text-sm text-black/70">events@rentalx.com</p>
    </article>
    <article class="rounded-2xl border border-black/10 bg-white p-5">
      <h2 class="text-lg font-semibold">Main office</h2>
      <p class="mt-2 text-sm text-black/70">2081 Green St, Riverside NC</p>
      <p class="text-sm text-black/70">Mon - Sun · 07:00 - 22:00</p>
    </article>
  </section>

  <section class="mx-auto mt-8 grid w-full max-w-6xl gap-6 px-4 pb-6 md:grid-cols-[1.1fr_0.9fr] md:px-6">
    <form class="rounded-3xl border border-black/10 bg-white p-6 md:p-8" data-rx-demo-form>
      <h2 class="text-2xl font-semibold">Send us a message</h2>
      <p class="mt-2 text-sm text-black/70">Tell us your preferred dates, guest count, and what kind of experience you want.</p>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <label class="text-sm">
          <span class="mb-1 block text-black/70">First name</span>
          <input type="text" required class="w-full rounded-xl border border-black/15 px-3 py-2 outline-none focus:border-[#ff4d4d]" />
        </label>
        <label class="text-sm">
          <span class="mb-1 block text-black/70">Last name</span>
          <input type="text" required class="w-full rounded-xl border border-black/15 px-3 py-2 outline-none focus:border-[#ff4d4d]" />
        </label>
        <label class="text-sm md:col-span-2">
          <span class="mb-1 block text-black/70">Email</span>
          <input type="email" required class="w-full rounded-xl border border-black/15 px-3 py-2 outline-none focus:border-[#ff4d4d]" />
        </label>
        <label class="text-sm md:col-span-2">
          <span class="mb-1 block text-black/70">Message</span>
          <textarea rows="5" class="w-full rounded-xl border border-black/15 px-3 py-2 outline-none focus:border-[#ff4d4d]"></textarea>
        </label>
      </div>

      <button type="submit" class="mt-5 rounded-full bg-[#ff4d4d] px-5 py-2.5 text-sm font-semibold text-white">Send message</button>
    </form>

    <aside class="space-y-6">
      <div class="overflow-hidden rounded-3xl border border-black/10 bg-white">
        <img
          src="https://images.unsplash.com/photo-1482192596544-9eb780fc7f66?auto=format&fit=crop&w=1400&q=80"
          alt="Resort map"
          class="h-72 w-full object-cover"
        />
      </div>
      <div class="rounded-3xl bg-[#ff4d4d] p-6 text-white">
        <h2 class="text-2xl font-semibold">Need immediate help?</h2>
        <p class="mt-2 text-sm text-white/85">Our concierge team can finalize your stay in minutes.</p>
        <a href="tel:+13215552001" class="mt-4 inline-flex rounded-full bg-white px-4 py-2 text-sm font-semibold text-[#ff4d4d]"
          >Call now</a
        >
      </div>
    </aside>
  </section>
</main>
