---
import { cabins } from '~/data/rental-x-pages';
---

<main>
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=2200&q=80"
      alt="Rooms"
      class="h-[44vh] min-h-[340px] w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="absolute inset-0 flex items-center justify-center px-4">
      <div class="text-center text-white">
        <p class="text-xs uppercase tracking-[0.18em] text-white/70">Rooms</p>
        <h1 class="mt-3 text-4xl font-semibold md:text-6xl">Rooms with WiFi</h1>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12 md:px-6">
    <div class="rounded-2xl border border-black/10 bg-white p-4 md:p-5">
      <form class="grid gap-3 md:grid-cols-4" data-rx-demo-form>
        <input class="rounded-xl border border-black/15 px-3 py-2 text-sm" placeholder="Check-in" />
        <input class="rounded-xl border border-black/15 px-3 py-2 text-sm" placeholder="Check-out" />
        <input class="rounded-xl border border-black/15 px-3 py-2 text-sm" placeholder="Guests" />
        <button class="rounded-xl bg-[#ff4d4d] px-4 py-2 text-sm font-semibold text-white">Find rooms</button>
      </form>
    </div>

    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {
        cabins.map((room) => (
          <article class="overflow-hidden rounded-3xl border border-black/10 bg-white">
            <img src={room.image} alt={room.name} class="h-56 w-full object-cover" />
            <div class="space-y-4 p-5">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h2 class="text-2xl font-semibold">{room.name}</h2>
                  <p class="mt-1 text-sm text-black/65">{room.type}</p>
                </div>
                <p class="rounded-full bg-[#ff4d4d]/10 px-3 py-1 text-sm font-semibold text-[#ff4d4d]">{room.price}/night</p>
              </div>
              <div class="grid grid-cols-2 gap-2 text-sm text-black/70">
                <p>Size: {room.size}</p>
                <p>Amenities: {room.wifi}</p>
              </div>
              <div class="flex gap-3">
                <a href="/rental-x/room-single" class="rounded-full bg-[#ff4d4d] px-4 py-2 text-sm font-semibold text-white">View room</a>
                <a href="/rental-x/contact-v1" class="rounded-full border border-black/15 px-4 py-2 text-sm font-semibold">Book now</a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</main>
