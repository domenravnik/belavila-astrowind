---
import { blogPosts } from '~/data/rental-x-pages';
---

<main>
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?auto=format&fit=crop&w=2200&q=80"
      alt="Blog category"
      class="h-[40vh] min-h-[300px] w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="absolute inset-0 flex items-center justify-center px-4 text-white">
      <div class="text-center">
        <p class="text-xs uppercase tracking-[0.18em] text-white/70">Category</p>
        <h1 class="mt-3 text-4xl font-semibold md:text-6xl">Travel Guide</h1>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-12 md:px-6">
    <div class="grid gap-5 md:grid-cols-2">
      {
        blogPosts.map((post) => (
          <article class="overflow-hidden rounded-2xl border border-black/10 bg-white">
            <img src={post.image} alt={post.title} class="h-52 w-full object-cover" />
            <div class="p-5">
              <div class="flex items-center gap-2 text-xs text-black/60">
                <span class="rounded-full bg-[#ff4d4d]/10 px-2 py-1 font-semibold text-[#ff4d4d]">{post.category}</span>
                <span>{post.date}</span>
              </div>
              <h2 class="mt-3 text-2xl font-semibold">{post.title}</h2>
              <p class="mt-3 text-sm text-black/70">{post.excerpt}</p>
              <a href="/rental-x/blog-post" class="mt-4 inline-flex rounded-full border border-black/15 px-4 py-2 text-sm font-semibold">Read more</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</main>
