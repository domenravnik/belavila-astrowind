<main>
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1470770841072-f978cf4d019e?auto=format&fit=crop&w=2200&q=80"
      alt="Private page"
      class="h-[44vh] min-h-[340px] w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="absolute inset-0 flex items-center justify-center px-4 text-white">
      <div class="text-center">
        <p class="text-xs uppercase tracking-[0.18em] text-white/70">Private access</p>
        <h1 class="mt-3 text-4xl font-semibold md:text-6xl">Password protected</h1>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-md px-4 py-14">
    <form class="rounded-3xl border border-black/10 bg-white p-8" data-rx-demo-form>
      <h2 class="text-2xl font-semibold">Enter password</h2>
      <p class="mt-2 text-sm text-black/70">This page is available for invited guests and members only.</p>
      <input
        type="password"
        placeholder="Password"
        class="mt-5 w-full rounded-xl border border-black/15 px-3 py-2 text-sm outline-none focus:border-[#ff4d4d]"
      />
      <button type="submit" class="mt-4 w-full rounded-full bg-[#ff4d4d] px-4 py-2.5 text-sm font-semibold text-white">Unlock</button>
    </form>
  </section>
</main>
