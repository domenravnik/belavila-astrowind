---
import { activities, cabins, testimonials } from '~/data/rental-x-pages';
---

<main>
  <section class="relative overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1455587734955-081b22074882?auto=format&fit=crop&w=2200&q=80"
      alt="Forest resort hero"
      class="h-[74vh] min-h-[560px] w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="absolute inset-0 flex items-center justify-center px-4">
      <div class="mx-auto max-w-3xl text-center text-white">
        <p class="text-xs uppercase tracking-[0.18em] text-white/75 md:text-sm">Forest Resort Experience</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight md:text-6xl">Recharge energies in our unique hotel</h1>
        <p class="mx-auto mt-4 max-w-2xl text-sm text-white/80 md:text-base">
          From handcrafted cabins to curated local adventures, every stay is designed to reset your pace.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/rental-x/rooms" class="rounded-full bg-[#ff4d4d] px-6 py-3 text-sm font-semibold text-white">Explore now</a>
          <a href="/rental-x/about" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-black">Learn more</a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-4 pt-14 md:px-6">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[#ff4d4d]">Explore our cabins</p>
        <h2 class="mt-2 text-3xl font-semibold">Choose your perfect stay</h2>
      </div>
      <div class="hidden gap-2 md:flex" data-rx-carousel>
        <button data-rx-prev class="rounded-full border border-black/15 px-3 py-2 text-sm">Prev</button>
        <button data-rx-next class="rounded-full border border-black/15 px-3 py-2 text-sm">Next</button>
      </div>
    </div>

    <div class="mt-6" data-rx-carousel>
      <div data-rx-track class="flex snap-x gap-4 overflow-x-auto pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {
          cabins.map((cabin) => (
            <article class="min-w-[300px] snap-start overflow-hidden rounded-2xl border border-black/10 bg-white shadow-sm md:min-w-[340px]">
              <img src={cabin.image} alt={cabin.name} class="h-44 w-full object-cover" />
              <div class="space-y-4 p-4">
                <div>
                  <h3 class="text-xl font-semibold">{cabin.name}</h3>
                  <p class="mt-1 text-sm text-black/65">{cabin.type}</p>
                </div>
                <div class="grid grid-cols-2 gap-3 text-sm text-black/70">
                  <p>{cabin.size}</p>
                  <p>{cabin.wifi}</p>
                </div>
                <div class="flex items-center justify-between">
                  <p class="text-lg font-semibold">{cabin.price}<span class="text-sm font-normal text-black/60"> / night</span></p>
                  <a href="/rental-x/room-single" class="rounded-full bg-[#ff4d4d] px-4 py-1.5 text-xs font-semibold text-white">Book now</a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
      <div class="mt-4 flex justify-end gap-2 md:hidden">
        <button data-rx-prev class="rounded-full border border-black/15 px-3 py-1.5 text-sm">Prev</button>
        <button data-rx-next class="rounded-full border border-black/15 px-3 py-1.5 text-sm">Next</button>
      </div>
    </div>
  </section>

  <section class="mx-auto mt-16 w-full max-w-6xl px-4 md:px-6">
    <h2 class="text-center text-3xl font-semibold">Come and enjoy one of a kind experience</h2>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        testimonials.map((item) => (
          <article class="rounded-2xl border border-black/10 bg-white p-4">
            <div class="flex items-center gap-3">
              <img src={item.image} alt={item.name} class="h-11 w-11 rounded-full object-cover" />
              <div>
                <p class="text-sm font-semibold">{item.name}</p>
                <p class="text-xs text-black/60">{item.role}</p>
              </div>
            </div>
            <p class="mt-3 text-sm text-black/70">{item.quote}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto mt-14 w-full max-w-6xl px-4 md:px-6">
    <div class="overflow-hidden rounded-3xl bg-[#ff4d4d] p-8 text-white md:p-10">
      <h2 class="max-w-xl text-3xl font-semibold">Recharge your energies in one of our forest cabins.</h2>
      <p class="mt-3 max-w-2xl text-sm text-white/85 md:text-base">
        Reserve direct for better rates, custom activity bundles, and flexible check-in support.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/rental-x/contact-v1" class="rounded-full bg-white px-5 py-2 text-sm font-semibold text-[#ff4d4d]">Book now</a>
        <a href="/rental-x/rooms" class="rounded-full border border-white/55 px-5 py-2 text-sm font-semibold">View rooms</a>
      </div>
    </div>
  </section>

  <section class="mx-auto mt-16 w-full max-w-6xl px-4 md:px-6">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.14em] text-[#ff4d4d]">Explore our activities</p>
    <h2 class="mt-2 text-center text-3xl font-semibold">Outdoor moments designed for every pace</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {
        activities.map((activity) => (
          <article class="overflow-hidden rounded-2xl border border-black/10 bg-white">
            <img src={activity.image} alt={activity.title} class="h-56 w-full object-cover" />
            <div class="p-4">
              <h3 class="text-lg font-semibold">{activity.title}</h3>
              <p class="mt-2 text-sm text-black/70">{activity.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto mt-16 grid w-full max-w-6xl gap-8 px-4 md:grid-cols-2 md:px-6">
    <div class="grid grid-cols-2 gap-3">
      <img
        src="https://images.unsplash.com/photo-1516483638261-f4dbaf036963?auto=format&fit=crop&w=1000&q=80"
        alt="Cabin exterior"
        class="h-44 w-full rounded-2xl object-cover"
      />
      <img
        src="https://images.unsplash.com/photo-1484154218962-a197022b5858?auto=format&fit=crop&w=1000&q=80"
        alt="Cozy interior"
        class="h-44 w-full rounded-2xl object-cover"
      />
      <img
        src="https://images.unsplash.com/photo-1472224371017-08207f84aaae?auto=format&fit=crop&w=1000&q=80"
        alt="Cabin details"
        class="h-44 w-full rounded-2xl object-cover"
      />
      <img
        src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1000&q=80"
        alt="Bedroom"
        class="h-44 w-full rounded-2xl object-cover"
      />
    </div>
    <div class="rounded-3xl bg-white p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[#ff4d4d]">Why us</p>
      <h2 class="mt-3 text-3xl font-semibold">What makes us different?</h2>
      <p class="mt-4 text-sm text-black/70 md:text-base">
        Every stay combines boutique-level comfort with a local-first itinerary. Our team plans each visit around your
        preferred rhythm, whether you want active days or deep rest.
      </p>
      <a href="/rental-x/about" class="mt-6 inline-flex rounded-full border border-black/15 px-4 py-2 text-sm font-semibold">Learn more</a>
    </div>
  </section>

  <section class="mx-auto mt-16 w-full max-w-6xl px-4 pb-6 md:px-6">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[#ff4d4d]">Testimonials</p>
        <h2 class="mt-2 text-3xl font-semibold">What our past clients say</h2>
      </div>
      <div class="hidden gap-2 md:flex" data-rx-carousel>
        <button data-rx-prev class="rounded-full border border-black/15 px-3 py-2 text-sm">Prev</button>
        <button data-rx-next class="rounded-full border border-black/15 px-3 py-2 text-sm">Next</button>
      </div>
    </div>

    <div class="mt-6" data-rx-carousel>
      <div data-rx-track class="flex snap-x gap-4 overflow-x-auto pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {
          testimonials.map((item) => (
            <article class="min-w-[320px] snap-start rounded-2xl border border-black/10 bg-white p-5 md:min-w-[420px]">
              <div class="flex items-center gap-3">
                <img src={item.image} alt={item.name} class="h-12 w-12 rounded-full object-cover" />
                <div>
                  <p class="font-semibold">{item.name}</p>
                  <p class="text-sm text-black/60">{item.role}</p>
                </div>
              </div>
              <p class="mt-4 text-sm text-black/70 md:text-base">“{item.quote}”</p>
            </article>
          ))
        }
      </div>
      <div class="mt-4 flex justify-end gap-2 md:hidden">
        <button data-rx-prev class="rounded-full border border-black/15 px-3 py-1.5 text-sm">Prev</button>
        <button data-rx-next class="rounded-full border border-black/15 px-3 py-1.5 text-sm">Next</button>
      </div>
    </div>
  </section>
</main>
